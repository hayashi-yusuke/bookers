<div class="edit-page">
<h1>Editing Book</h1>

<%= form_with model: @book, html:{ class: "book-form" } do |f| %>

  <p>
    Title<br>
    <%= f.text_field :title %>
  </p>

  <p>
    Body<br>
    <%= f.text_area :body %>
  </p>

  <p>
    <%= f.submit "Update Book" %>
  </p>

<% end %>

  <div class="book-links">
    <%= link_to "Show", book_path(@book) %> |
    <%= link_to "Back", books_path %>
  </div>
</div>